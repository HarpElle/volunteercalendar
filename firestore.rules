rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Assignments — collection group query for token-based volunteer confirmation
    // Security: confirmation_token is a UUID — knowing it IS the authorization
    // Only status + responded_at can be changed via unauthenticated update
    match /{path=**}/assignments/{assignId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'responded_at']);
    }

    // Waitlist — anyone can write, only admins can read
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Users — authenticated users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Churches — members can read, admins can write
    match /churches/{churchId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId;
      // Allow church creation when churchId matches the user's UID (setup bootstrap)
      allow create: if request.auth != null && request.auth.uid == churchId;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Church subcollections — same church-level access
      match /{subcollection}/{docId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId;
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'team_lead'];
      }

      // Nested subcollections (e.g., schedules/{id}/assignments/{id})
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId;
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.church_id == churchId &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'team_lead'];
      }
    }
  }
}

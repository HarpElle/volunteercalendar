rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    // Membership doc ID is {userId}_{churchId} (deterministic)
    function membershipRef(churchId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + churchId);
    }

    function getMembership(churchId) {
      return get(membershipRef(churchId));
    }

    function isActiveMember(churchId) {
      return request.auth != null
        && exists(membershipRef(churchId))
        && getMembership(churchId).data.status == 'active';
    }

    function memberRole(churchId) {
      return getMembership(churchId).data.role;
    }

    function isOrgAdmin(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['admin', 'owner'];
    }

    function isOrgOwner(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) == 'owner';
    }

    function isSchedulerOrAbove(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['scheduler', 'admin', 'owner'];
    }

    // ─── Assignments (collection group) ───
    // Confirmation reads/writes now go through Admin SDK in /api/confirm.
    // Dashboard reads use subcollection rules at churches/{churchId}/...
    // No collection group rule needed.

    // ─── User Notifications ───
    match /user_notifications/{notifId} {
      // Users can read their own notifications
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;

      // Users can mark their own notifications as read (only the "read" field)
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Only Admin SDK can create/delete
      allow create, delete: if false;
    }

    // ─── Event Signups ───
    match /event_signups/{docId} {
      // Org admins can read signups for their church
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Users can read their own signups
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // ─── Waitlist ───
    // No client writes; routed through /api/waitlist with reCAPTCHA (Track A.3).
    match /waitlist/{docId} {
      allow read, write: if false;
    }

    // ─── User Profiles ───
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Memberships ───
    // Doc ID format: {userId}_{churchId}
    match /memberships/{membershipId} {
      // Users can read their own memberships
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;

      // Org admins can read any membership for their church
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Bootstrap: user can create their own owner membership for a church they own (churchId === uid)
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.church_id == request.auth.uid
        && request.resource.data.role == 'owner'
        && request.resource.data.status == 'active';

      // Users can create their own membership (self-registration → pending_org_approval)
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending_org_approval'
        && request.resource.data.role == 'volunteer';

      // Org admins can create memberships (inviting someone → pending_volunteer_approval)
      allow create: if request.auth != null
        && isOrgAdmin(request.resource.data.church_id)
        && request.resource.data.status == 'pending_volunteer_approval';

      // Users can accept their own pending invite
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && resource.data.status == 'pending_volunteer_approval'
        && request.resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at']);

      // Users can update their own reminder preferences
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reminder_preferences', 'updated_at']);

      // Org admins can update memberships (approve, change role, deactivate)
      allow update: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Org owners can delete memberships; users can leave (delete own)
      allow delete: if request.auth != null
        && (resource.data.user_id == request.auth.uid
            || isOrgOwner(resource.data.church_id));
    }

    // ─── Churches ───
    match /churches/{churchId} {
      // Any active member can read their church; bootstrap allows owner to read own church
      allow read: if isActiveMember(churchId)
        || (request.auth != null && request.auth.uid == churchId);

      // Bootstrap: user can create a church doc with their UID as the ID
      allow create: if request.auth != null && request.auth.uid == churchId;

      // Admins/owners can update; bootstrap allows owner to update own church during setup
      allow update: if isOrgAdmin(churchId)
        || (request.auth != null && request.auth.uid == churchId);

      // Only owner can delete a church
      allow delete: if isOrgOwner(churchId);

      // ─── Invite queue (admin-only) ───
      match /invite_queue/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Volunteer-readable, scheduler+ writable (operational data)
      // ════════════════════════════════════════════════════════════════

      match /people/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /ministries/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /services/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /schedules/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);

        // Nested assignments under a schedule (collection group queries elsewhere)
        match /assignments/{assignmentId} {
          allow read: if isActiveMember(churchId);
          allow write: if isSchedulerOrAbove(churchId);
        }
      }

      match /assignments/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /events/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /service_plans/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);

        match /arrangements/{arrId} {
          allow read: if isActiveMember(churchId);
          allow write: if isSchedulerOrAbove(churchId);
        }
      }

      match /songs/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /song_usage/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /swap_requests/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isActiveMember(churchId);
      }

      match /campuses/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /calendar_feeds/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /prerequisites/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /ministry_templates/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /training_sessions/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Admin-only operational data
      // ════════════════════════════════════════════════════════════════

      match /rooms/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /roomSettings/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /reservations/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /reservation_requests/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isActiveMember(churchId);
      }

      match /import_logs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /integrations/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /sent_notifications/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /pending_invites/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /activity/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      // ════════════════════════════════════════════════════════════════
      // Children's check-in data — Admin SDK only via /api/checkin/*
      // ════════════════════════════════════════════════════════════════

      match /children/{docId} {
        allow read, write: if false;
      }

      match /households/{docId} {
        allow read, write: if false;
      }

      match /checkin_households/{docId} {
        allow read, write: if false;
      }

      match /checkInSessions/{docId} {
        allow read, write: if false;
      }

      match /checkinAlerts/{docId} {
        allow read, write: if false;
      }

      match /check_in_codes/{docId} {
        allow read, write: if false;
      }

      // Settings + rooms config: org-admin readable for setup screens.
      match /checkinSettings/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /checkinRooms/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Sensitive — Admin SDK only (track B + track F land here)
      // ════════════════════════════════════════════════════════════════

      match /audit_logs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /kiosk_tokens/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      match /notification_outbox/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      match /pending_visitor_registrations/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      match /feedback/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow create: if isActiveMember(churchId);
        allow update, delete: if false;
      }

      match /billing/{docId} {
        allow read: if isOrgOwner(churchId);
        allow write: if false; // Admin SDK only via Stripe webhook
      }

      match /cron_runs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      // No catch-all wildcard. Any new subcollection MUST be added explicitly above
      // (deliberate default-deny). If you add a new feature and Firestore is denying
      // a read/write you expected, add the rule here.
    }

    // ─── Facility Groups ───
    // KNOWN ISSUE: client-list query reads all groups, then filters on members
    // subcollection. Tightening this requires denormalizing group membership
    // into the user's church doc (track A.3). Until then, kept at auth-only
    // read to not break the existing management UI.
    match /facility_groups/{groupId} {
      allow read: if request.auth != null;

      // Org admins can create a facility group
      allow create: if request.auth != null
        && isOrgAdmin(request.resource.data.created_by_church_id);

      // Only the creator org's admins can update/delete the group
      allow update: if request.auth != null
        && isOrgAdmin(resource.data.created_by_church_id);

      allow delete: if request.auth != null
        && isOrgAdmin(resource.data.created_by_church_id);

      // ─── Facility Group Members ───
      match /members/{memberId} {
        // Auth-only read until track A.3 narrows this.
        allow read: if request.auth != null;

        // Admins of the inviting org can add members
        allow create: if request.auth != null
          && isOrgAdmin(request.resource.data.invited_by_church_id);

        // Admins of the member's own org can accept invite or update
        allow update: if request.auth != null
          && isOrgAdmin(resource.data.church_id);

        // Admins of the member's own org can leave (delete)
        allow delete: if request.auth != null
          && isOrgAdmin(resource.data.church_id);
      }
    }

    // ─── Stage Sync Live (token IS the auth) ───
    // The doc ID is a high-entropy token, so reads are intentionally public
    // for the stage display page. Server proxy via /api/stage/* lands in
    // track A.3. Until then, keep behavior unchanged.
    match /stage_sync_live/{token} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    match /stage_sync_tokens/{token} {
      allow read, write: if false; // Admin SDK only
    }

    // ─── Short Links ───
    match /short_links/{linkId} {
      // Resolution happens server-side; admins can list/manage their own.
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);
      allow write: if request.auth != null
        && isOrgAdmin(request.resource.data.church_id);
    }

    // ─── Push Tokens (FCM device tokens) ───
    match /push_tokens/{tokenId} {
      allow read, write: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // ─── Stripe processed events (idempotency cache; Admin SDK only) ───
    match /stripe_processed_events/{eventId} {
      allow read, write: if false;
    }

    // ─── Platform admin data (Admin SDK only) ───
    // platform/stats and platform/recent_activity are aggregate docs;
    // platform_orgs/{churchId} are per-org snapshots. All accessed via
    // server-only routes that verify isPlatformAdmin().
    match /platform/{docId} {
      allow read, write: if false;
    }
    match /platform_orgs/{churchId} {
      allow read, write: if false;
    }

    // No global wildcard. Any new top-level collection requires an explicit rule.
  }
}

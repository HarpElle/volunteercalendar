rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    // Membership doc ID is {userId}_{churchId} (deterministic)
    function membershipRef(churchId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + churchId);
    }

    function getMembership(churchId) {
      return get(membershipRef(churchId));
    }

    function isActiveMember(churchId) {
      return request.auth != null
        && exists(membershipRef(churchId))
        && getMembership(churchId).data.status == 'active';
    }

    function memberRole(churchId) {
      return getMembership(churchId).data.role;
    }

    function isOrgAdmin(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['admin', 'owner'];
    }

    function isOrgOwner(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) == 'owner';
    }

    function isSchedulerOrAbove(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['scheduler', 'admin', 'owner'];
    }

    // ─── Phase 3: child private-medical access ───
    // Who may READ churches/{c}/people/{id}/private/medical (date_of_birth,
    // allergies, medical_notes, medications, authorized_pickups): admins/
    // owners + members with a check-in role. Ordinary volunteers + plain
    // schedulers cannot. Writes are Admin-SDK-only (see the match block).
    function hasCheckinPrivateRead(churchId) {
      return isActiveMember(churchId)
        && (
          memberRole(churchId) in ['admin', 'owner']
          || getMembership(churchId).data.checkin_volunteer == true
          || getMembership(churchId).data.checkin_manager == true
        );
    }

    // Guardrail: a client write to a parent people doc must NOT (re)introduce
    // the five private child-medical keys into child_profile. Firestore rules
    // can't redact fields on read, so the parent doc must stay physically
    // free of them — this is the write-time enforcement. KEEP IN SYNC with
    // PRIVATE_MEDICAL_FIELDS in src/lib/server/child-medical.ts.
    function parentPersonHasNoPrivateChildMedical(data) {
      return !('child_profile' in data)
        || !(
          'date_of_birth' in data.child_profile
          || 'allergies' in data.child_profile
          || 'medical_notes' in data.child_profile
          || 'medications' in data.child_profile
          || 'authorized_pickups' in data.child_profile
        );
    }

    // ─── Assignments (collection group) ───
    // Confirmation reads/writes now go through Admin SDK in /api/confirm.
    // Dashboard reads use subcollection rules at churches/{churchId}/...
    // No collection group rule needed.

    // ─── User Notifications ───
    match /user_notifications/{notifId} {
      // Users can read their own notifications
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;

      // Users can mark their own notifications as read (only the "read" field)
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Only Admin SDK can create/delete
      allow create, delete: if false;
    }

    // ─── Event Signups ───
    match /event_signups/{docId} {
      // Org admins can read signups for their church
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Users can read their own signups
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // ─── Waitlist ───
    // No client writes; routed through /api/waitlist with reCAPTCHA (Track A.3).
    match /waitlist/{docId} {
      allow read, write: if false;
    }

    // ─── MFA recovery codes (Wave 4.2) ───
    // Server-only via Admin SDK. Doc id = user uid. Contains hashed
    // (bcrypt) one-time recovery codes for users with TOTP MFA enabled.
    // Clients never read or write directly; everything routes through
    // /api/account/mfa/* endpoints so the audit_logs trail is reliable
    // and the bcrypt hashes never leak.
    match /user_recovery_codes/{userId} {
      allow read, write: if false;
    }

    // ─── User Profiles ───
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Memberships ───
    // Doc ID format: {userId}_{churchId}
    match /memberships/{membershipId} {
      // Users can read their own memberships
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;

      // Org admins can read any membership for their church
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Bootstrap: user can create their own owner membership for a church they own (churchId === uid)
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.church_id == request.auth.uid
        && request.resource.data.role == 'owner'
        && request.resource.data.status == 'active';

      // Users can create their own membership (self-registration → pending_org_approval)
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending_org_approval'
        && request.resource.data.role == 'volunteer';

      // Org admins can create memberships (inviting someone → pending_volunteer_approval)
      allow create: if request.auth != null
        && isOrgAdmin(request.resource.data.church_id)
        && request.resource.data.status == 'pending_volunteer_approval';

      // Users can accept their own pending invite
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && resource.data.status == 'pending_volunteer_approval'
        && request.resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at']);

      // Users can update their own reminder + scheduler-notification
      // preferences. Both are user-settings on the membership doc.
      // Phase 1.2 fix: scheduler_notification_preferences was previously
      // omitted, so the Account page's direct-client write was silently
      // rejected by rules — schedulers thought they'd disabled emails
      // but never had.
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reminder_preferences', 'scheduler_notification_preferences', 'updated_at']);

      // Org admins can update memberships (approve, change role, deactivate)
      allow update: if request.auth != null
        && isOrgAdmin(resource.data.church_id);

      // Org owners can delete memberships; users can leave (delete own)
      allow delete: if request.auth != null
        && (resource.data.user_id == request.auth.uid
            || isOrgOwner(resource.data.church_id));
    }

    // ─── Churches ───
    match /churches/{churchId} {
      // Any active member can read their church; bootstrap allows owner to read own church
      allow read: if isActiveMember(churchId)
        || (request.auth != null && request.auth.uid == churchId);

      // Bootstrap: user can create a church doc with their UID as the ID
      allow create: if request.auth != null && request.auth.uid == churchId;

      // Admins/owners can update; bootstrap allows owner to update own church during setup
      allow update: if isOrgAdmin(churchId)
        || (request.auth != null && request.auth.uid == churchId);

      // Only owner can delete a church
      allow delete: if isOrgOwner(churchId);

      // ─── Invite queue (admin-only) ───
      match /invite_queue/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Volunteer-readable, scheduler+ writable (operational data)
      // ════════════════════════════════════════════════════════════════

      match /people/{docId} {
        allow read: if isActiveMember(churchId);
        // Scheduler+ writes, but the parent doc must NEVER carry the five
        // private child-medical keys (Phase 3). Those live in the private
        // subcollection below and are written Admin-SDK-side.
        allow write: if isSchedulerOrAbove(churchId)
          && parentPersonHasNoPrivateChildMedical(request.resource.data);

        // Phase 3: private child-medical data (date_of_birth, allergies,
        // medical_notes, medications, authorized_pickups). Read-gated to
        // admins + check-in roles; writes are Admin-SDK-only so they're
        // audited + validated server-side (no direct client writes).
        match /private/{privateDocId} {
          allow read: if privateDocId == 'medical'
            && hasCheckinPrivateRead(churchId);
          allow write: if false;
        }
      }

      match /ministries/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /services/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /schedules/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);

        // Nested assignments under a schedule. Assignments actually live at
        // the top-level churches/{churchId}/assignments subcollection; this
        // path is kept rule-consistent with the same schedule_status gate as
        // defense-in-depth in case any doc is ever written here.
        match /assignments/{assignmentId} {
          allow read: if isActiveMember(churchId) && (
            isSchedulerOrAbove(churchId)
            || resource.data.get('schedule_status', '') in ['published', 'archived']
          );
          allow write: if isSchedulerOrAbove(churchId);
        }
      }

      // ─── Assignments ───
      // SECURITY HISTORY (Codex QA 2026-05-15 → Run 2 2026-05-16 → Wave 2.2b 2026-05-28):
      //
      //   Round 1 (05-15) tried to deny non-published assignments to
      //   volunteers via `get(/.../schedules/$(resource.data.schedule_id))`.
      //   That works for single-doc reads but BREAKS list queries — a
      //   cross-document get() can't be statically proven safe for every
      //   matching doc, so the volunteer My Schedule getDocs() was rejected
      //   outright ("schedule_id is undefined").
      //
      //   Round 2 (05-16) reverted to "any active member reads all
      //   assignments" and pushed draft-hiding to the app layer as a stopgap.
      //
      //   Wave 2.2b (05-28) does the real rule-layer fix: the parent
      //   schedule's status is denormalized onto every assignment as
      //   `schedule_status` (src/lib/server/schedule-status-fanout.ts, the
      //   claim route, and auto-reschedule all stamp it; a one-time backfill
      //   covered legacy docs). The rule reads that field with a DEFAULTED map
      //   accessor — resource.data.get('schedule_status', '') — which is safe
      //   inside list queries (no cross-doc get) and treats a missing-field
      //   legacy orphan as non-published, i.e. denied to volunteers (the safe
      //   default).
      //
      //   Volunteer-visible reads now flow through the Admin SDK endpoint
      //   /api/my-schedule, which re-applies the self-signup carve-out the
      //   rule intentionally omits (own self_signup claims on a draft schedule
      //   stay visible there, but NOT via raw client query). The one remaining
      //   volunteer CLIENT read — SmartCheckInBanner — constrains its query
      //   with where('schedule_status','==','published') so it stays
      //   rule-legal. Scheduler+ keep full read access via the
      //   isSchedulerOrAbove branch (admin pages: Service Day, Schedules,
      //   People analytics).
      match /assignments/{docId} {
        allow read: if isActiveMember(churchId) && (
          isSchedulerOrAbove(churchId)
          || resource.data.get('schedule_status', '') in ['published', 'archived']
        );
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /events/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /service_plans/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);

        match /arrangements/{arrId} {
          allow read: if isActiveMember(churchId);
          allow write: if isSchedulerOrAbove(churchId);
        }
      }

      match /songs/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /song_usage/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /swap_requests/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isActiveMember(churchId);
      }

      match /campuses/{docId} {
        // Pass H Phase 5 (2026-05-25): split write so create/update
        // stay client-allowed but delete is forced through
        // /api/campuses/[id] (Admin SDK + cascade). Bare client
        // deletes would orphan campus_id references on services,
        // events, calendar_feeds, and people.campus_ids arrays.
        allow read: if isActiveMember(churchId);
        allow create, update: if isSchedulerOrAbove(churchId);
        allow delete: if false;
      }

      // ─── Calendar Feeds ───
      // SECURITY (Codex QA 2026-05-15): only the user who created a feed
      // may read or manage it. Feeds carry `created_by_user_id`; the feed
      // token at /api/calendar is still public-by-token but the API now
      // performs additional checks. See plan i-want-you-to-iterative-spring.md
      // Layer 1.
      match /calendar_feeds/{docId} {
        allow read: if isActiveMember(churchId)
                    && resource.data.created_by_user_id == request.auth.uid;
        allow create: if isActiveMember(churchId)
                      && request.resource.data.created_by_user_id == request.auth.uid;
        allow update, delete: if isActiveMember(churchId)
                              && resource.data.created_by_user_id == request.auth.uid;
      }

      match /prerequisites/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /ministry_templates/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /training_sessions/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Admin-only operational data
      // ════════════════════════════════════════════════════════════════

      match /rooms/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /roomSettings/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /reservations/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isSchedulerOrAbove(churchId);
      }

      match /reservation_requests/{docId} {
        allow read: if isActiveMember(churchId);
        allow write: if isActiveMember(churchId);
      }

      match /import_logs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /integrations/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /sent_notifications/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /pending_invites/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /activity/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      // ════════════════════════════════════════════════════════════════
      // Children's check-in data — Admin SDK only via /api/checkin/*
      // ════════════════════════════════════════════════════════════════

      match /children/{docId} {
        allow read, write: if false;
      }

      match /households/{docId} {
        // People-side households (volunteer scheduling families). The
        // Families tab in /dashboard/people writes here via the client
        // SDK to set scheduling preferences (never_same_service /
        // prefer_same_service / never_same_time) and member lists.
        //
        // Codex Pass H Phase 3 retest Sev 2 (2026-05-25): prior
        // `allow read, write: if false` was inherited from when this
        // collection was assumed Admin-SDK-only via /api/checkin/*. In
        // practice the People Families tab has always used client
        // writes, which silently failed (modal stayed open, no card
        // update). UI gates with `canManage = isAdmin(...)` so rule
        // mirrors with isOrgAdmin. Reads stay server-side via
        // /api/people-data for now but are also permitted to org
        // admins for direct-read paths in the future.
        //
        // Check-in flows continue to use the Admin SDK from
        // /api/checkin/* and are unaffected by these client-side rules.
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /checkin_households/{docId} {
        allow read, write: if false;
      }

      match /checkInSessions/{docId} {
        allow read, write: if false;
      }

      match /checkinAlerts/{docId} {
        allow read, write: if false;
      }

      match /check_in_codes/{docId} {
        allow read, write: if false;
      }

      // Wave 9 P0-2 — Blocked-pickup contacts (the "Not Authorized" list).
      //
      // Stored in its own subcollection rather than embedded on the child
      // Person doc because `people/{docId}` is volunteer-readable (line 174);
      // embedding custody-order data there would leak the most sensitive
      // surface in the system to every active member. Server-only access
      // matches `checkInSessions` / `check_in_codes` / `checkinAlerts`.
      //
      // Each doc carries `scope: "child" | "household"` and the relevant
      // `child_id` / `household_id`. See `BlockedPickup` in src/lib/types.
      match /checkin_blocked_pickups/{docId} {
        allow read, write: if false; // Admin SDK only via /api/admin/checkin/*
      }

      // Wave 9 P0-5 — Worker (volunteer) room check-ins.
      //
      // Tracks the ADULTS responsible for a room throughout the
      // service (distinct from checkInSessions which tracks CHILDREN).
      // Server-only access via the /api/checkin/room-volunteer-*
      // routes — clients never read or write directly. Matches the
      // checkInSessions / checkinAlerts privacy boundary.
      match /roomVolunteerCheckins/{docId} {
        allow read, write: if false;
      }

      // Wave 9 P0-5C race-fix — Room check-in serialization locks.
      //
      // One doc per (room_id, service_date) used purely as a
      // Firestore-transaction conflict point. The kiosk children-
      // check-in route tx.get()s + tx.set()s this doc inside the
      // gate transaction so two concurrent batches targeting the
      // same room can't both commit. Doc content is throwaway
      // (last_checkin_at only). Server-only.
      match /roomCheckinLocks/{docId} {
        allow read, write: if false;
      }

      // Settings + rooms config: org-admin readable for setup screens.
      match /checkinSettings/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      match /checkinRooms/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if isOrgAdmin(churchId);
      }

      // ════════════════════════════════════════════════════════════════
      // Sensitive — Admin SDK only (track B + track F land here)
      // ════════════════════════════════════════════════════════════════

      match /audit_logs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      match /kiosk_tokens/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      // 2026-06-04: admin → kiosk command queue. Created by the
      // POST /api/admin/kiosk-commands route, polled by the kiosk via
      // GET /api/checkin/kiosk-commands, marked complete via PATCH —
      // all server-side via Admin SDK.
      match /kiosk_commands/{cmdId} {
        allow read, write: if false; // Admin SDK only
      }

      // Wave 10 W10-5A: per-household Apple/Google Wallet pass
      // records. Admin SDK writes only — the wallet-pass endpoints
      // do all the auth + download bookkeeping server-side.
      match /wallet_passes/{householdId} {
        allow read, write: if false;
      }

      match /notification_outbox/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      match /pending_visitor_registrations/{docId} {
        allow read, write: if false; // Admin SDK only
      }

      match /feedback/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow create: if isActiveMember(churchId);
        allow update, delete: if false;
      }

      match /billing/{docId} {
        allow read: if isOrgOwner(churchId);
        allow write: if false; // Admin SDK only via Stripe webhook
      }

      match /cron_runs/{docId} {
        allow read: if isOrgAdmin(churchId);
        allow write: if false; // Admin SDK only
      }

      // No catch-all wildcard. Any new subcollection MUST be added explicitly above
      // (deliberate default-deny). If you add a new feature and Firestore is denying
      // a read/write you expected, add the rule here.
    }

    // ─── Facility Groups ───
    // KNOWN ISSUE: client-list query reads all groups, then filters on members
    // subcollection. Tightening this requires denormalizing group membership
    // into the user's church doc (track A.3). Until then, kept at auth-only
    // read to not break the existing management UI.
    match /facility_groups/{groupId} {
      allow read: if request.auth != null;

      // Org admins can create a facility group
      allow create: if request.auth != null
        && isOrgAdmin(request.resource.data.created_by_church_id);

      // Only the creator org's admins can update/delete the group
      allow update: if request.auth != null
        && isOrgAdmin(resource.data.created_by_church_id);

      allow delete: if request.auth != null
        && isOrgAdmin(resource.data.created_by_church_id);

      // ─── Facility Group Members ───
      match /members/{memberId} {
        // Auth-only read until track A.3 narrows this.
        allow read: if request.auth != null;

        // Admins of the inviting org can add members
        allow create: if request.auth != null
          && isOrgAdmin(request.resource.data.invited_by_church_id);

        // Admins of the member's own org can accept invite or update
        allow update: if request.auth != null
          && isOrgAdmin(resource.data.church_id);

        // Pass G Phase 4: OWNER only (not any admin) can leave. Plan §4.5 —
        // leaving silently disconnects shared-room visibility from the
        // partner org, which can disrupt coordination. Restrict to the
        // role most accountable for external organizational relationships.
        allow delete: if request.auth != null
          && isOrgOwner(resource.data.church_id);
      }
    }

    // ─── Stage Sync Live (capability URL pattern) ───
    //
    // The doc ID IS the auth credential — a high-entropy token only known
    // to clients holding the capability URL. Firestore enforces that this
    // rule applies to single-doc reads (`get`), NOT collection list/query
    // operations, so an unauthorized caller cannot enumerate the collection.
    // This is the standard capability-URL pattern (same shape Google Docs
    // uses for "anyone with the link can view").
    //
    // SAFETY CONTRACT: documents in stage_sync_live MUST contain only
    // information intended for projection on a public stage display
    // (current lyrics line, song title, scripture reference). Never store
    // PII, member lists, full song catalogs, or anything sensitive in this
    // collection. Server-side writers (`/api/stage/*`) enforce this.
    match /stage_sync_live/{token} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    match /stage_sync_tokens/{token} {
      allow read, write: if false; // Admin SDK only
    }

    // ─── Short Links ───
    match /short_links/{linkId} {
      // Resolution happens server-side; admins can list/manage their own.
      allow read: if request.auth != null
        && isOrgAdmin(resource.data.church_id);
      allow write: if request.auth != null
        && isOrgAdmin(request.resource.data.church_id);
    }

    // ─── Push Tokens (FCM device tokens) ───
    match /push_tokens/{tokenId} {
      allow read, write: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // ─── Stripe processed events (idempotency cache; Admin SDK only) ───
    match /stripe_processed_events/{eventId} {
      allow read, write: if false;
    }

    // ─── Kiosk Stations + Activation Codes + Tokens (Track B; Admin SDK only) ───
    // All kiosk identity lives server-side. Activation codes are short-lived
    // and consumed via /api/kiosk/activate. The /api/admin/kiosk/* routes
    // verify org-admin role before any read/write.
    match /kiosk_stations/{stationId} {
      allow read, write: if false;
    }
    match /kiosk_activations/{code} {
      allow read, write: if false;
    }
    match /kiosk_tokens/{tokenId} {
      allow read, write: if false;
    }

    // ─── Platform admin data (Admin SDK only) ───
    // platform/stats and platform/recent_activity are aggregate docs;
    // platform_orgs/{churchId} are per-org snapshots. All accessed via
    // server-only routes that verify isPlatformAdmin().
    match /platform/{docId} {
      allow read, write: if false;
    }
    match /platform_orgs/{churchId} {
      allow read, write: if false;
    }

    // Cron run history (Wave 2.3). Top-level docs written by Admin SDK from
    // every cron route via withCronRun(). The platform admin "Cron Runs"
    // page reads via /api/platform/cron-runs which checks isPlatformAdmin.
    match /cron_runs/{docId} {
      allow read, write: if false;
    }

    // No global wildcard. Any new top-level collection requires an explicit rule.
  }
}

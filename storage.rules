rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Volunteer profile photos — read for any authenticated user, writes via Admin SDK only
    match /churches/{churchId}/volunteer_photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // All uploads go through Admin SDK in API routes
    }

    // User profile photos — read for any authenticated user, writes via Admin SDK only
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // All uploads go through Admin SDK in API routes
    }

    // Children's check-in photos (Wave 9 P0-2): authorized-pickup contacts
    // + blocked-pickup contacts. This is the most sensitive surface in the
    // app — custody disputes, court orders, faces of people the household
    // does NOT want to pick the child up. NEVER expose unsigned URLs.
    //
    // Reads: Admin SDK only via /api/admin/checkin/photo/* or the
    // staffed-station-scoped kiosk endpoint (`signed URLs returned per
    // request, short TTL`). Direct client reads are denied here.
    //
    // Writes: Admin SDK only (API routes apply admin-membership + scope
    // checks before persisting).
    match /churches/{churchId}/checkin-photos/{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }

    // Wave 11 Org Branding: church/org logos. PUBLIC read because the
    // logo renders on unauthenticated surfaces (Apple Wallet pass, email
    // headers for parents who don't have an account, kiosk welcome
    // screen, /guardian magic-link portal). The logo is by design
    // non-secret. Writes via Admin SDK only — the upload route
    // (`/api/admin/org/branding/logo`) gates on admin/owner role +
    // sharp-validates the bytes before storing.
    match /churches/{churchId}/branding/{file=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

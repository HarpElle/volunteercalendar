# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# migration artifacts
migration-map.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Local testing workspace — credentials, session notes, screenshots, etc.
# Never push to GitHub.
/TestingResources/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent / tooling workspaces (machine-specific, not committed)
.agents/
VolunteerCalTestingByCodex/
coordination/

# Firestore emulator runtime log (regenerated on every emulator run)
firestore-debug.log


# Apple PassKit + Google Wallet provisioning artifacts (private keys, CSRs, P12s)
docs/PassInformation/
